<!DOCTYPE html>
<html>
<head>
    <title>Dashboard</title>

    <link rel="stylesheet" href="/css/dashboard.css">
</head>

<body>

<nav class="navbar">

    <h2>Attendance Taker</h2>

    <a href="/logout" class="logout-btn">
        Logout
    </a>

</nav>

<div class="dashboard-container">

    <div class="hero">

        <h1>
            Welcome Back 
        </h1>

        <p>
            Manage attendance registers and generate
            QR-based attendance sessions.
        </p>

    </div>

    <div class="dashboard-grid">

        <div class="dashboard-card">

            <h3>Create Register</h3>

            <p>
                Create a new register and upload
                student records.
            </p>

            <a href="/registers/new">
                Open →
            </a>

        </div>

        <div class="dashboard-card">

            <h3>View Registers</h3>

            <p>
                Access existing registers and
                generate attendance QR codes.
            </p>

            <a href="/registers">
                Open →
            </a>

        </div>

    </div>

    <div class="hero-image">

        <img
            src="/images/dashboard.svg"
            alt="Dashboard Illustration"
        >

    </div>

</div>

</body>
</html>
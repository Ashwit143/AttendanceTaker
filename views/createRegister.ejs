<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport"
        content="width=device-width, initial-scale=1.0">

    <title>Create Register</title>

    <link rel="stylesheet"
        href="/css/registers.css">

</head>

<body>

<div class="create-container">

    <div class="create-card">

        <div class="create-left">

            <img
                src="/images/create-register.svg"
                alt="Create Register">

        </div>

        <div class="create-right">

            <div class="form-header">

                <h1>Create Register</h1>

                <p>
                    Create a new attendance register
                    and upload your student list.
                </p>

            </div>

            <form
                action="/registers/new"
                method="POST"
                enctype="multipart/form-data"
            >

                <div class="input-group">

                    <label>
                        Subject
                    </label>

                    <input
                        type="text"
                        name="subject"
                        placeholder="Enter Subject"
                        required>

                </div>

                <div class="input-group">

                    <label>
                        Section
                    </label>

                    <input
                        type="text"
                        name="section"
                        placeholder="Enter Section"
                        required>

                </div>

                <div class="input-group">

                    <label>
                        Student Register
                    </label>

                    <input
                        type="file"
                        name="excelFile"
                        accept=".xlsx,.xls"
                        required>

                </div>

                <button
                    class="create-btn"
                    type="submit">

                    Create Register

                </button>

            </form>

        </div>

    </div>

</div>

</body>

</html>
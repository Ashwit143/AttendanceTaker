<!DOCTYPE html>
<html>
<head>
    <title>Create Register</title>
</head>
<body>

    <h1>Create Register</h1>

    <form
        action="/registers/new"
        method="POST"
        enctype="multipart/form-data"
    >

        <input
            type="text"
            name="section"
            placeholder="Section"
            required
        >

        <br><br>

        <input
            type="text"
            name="subject"
            placeholder="Subject"
            required
        >

        <br><br>

        <input
            type="file"
            name="excelFile"
            accept=".xlsx,.xls"
            required
        >

        <br><br>

        <button type="submit">
            Create Register
        </button>

    </form>

</body>
</html>
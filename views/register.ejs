<!DOCTYPE html>
<html>
<head>
    <title>Professor Registration</title>
</head>
<body>

    <h1>Professor Registration</h1>

    <form action="/register" method="POST">

        <input
            type="text"
            name="name"
            placeholder="Enter Name"
            required
        >

        <br><br>

        <input
            type="email"
            name="email"
            placeholder="Enter Email"
            required
        >

        <br><br>

        <input
            type="password"
            name="password"
            placeholder="Enter Password"
            required
        >

        <br><br>

        <button type="submit">
            Register
        </button>

    </form>

</body>
</html>
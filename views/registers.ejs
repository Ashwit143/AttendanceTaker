<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Registers</title>

    <link rel="stylesheet" href="/css/registers.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">

</head>

<body>

    <div class="registers-header">

        <div class="header-left">

            <h1>My Registers</h1>

            <p>
                Manage attendance registers and generate
                attendance QR sessions.
            </p>

        </div>

        <a href="/registers/new" class="new-register-btn">
            + New Register
        </a>

    </div>

    <% if(registers.length===0){ %>

        <div class="empty-state">

            <div class="empty-icon">
                📚
            </div>

            <h2>No Registers Yet</h2>

            <p>
                Create your first attendance register to start
                managing classroom attendance.
            </p>

            <a href="/registers/new" class="create-btn">
                Create Register
            </a>

        </div>

        <% } else { %>

            <div class="register-grid">

                <% registers.forEach((register,index)=>{ %>

                    <div class="register-card <%= index % 2 === 0 ? 'dark' : 'light' %>">

                        <div>

                            <p class="card-label">
                                SECTION <%= register.section %>
                            </p>

                            <h2 class="card-title">
                                <%= register.subject %>
                            </h2>

                            <p class="card-description">
                                Generate attendance sessions and manage records.
                            </p>

                        </div>

                        <form action="/generate/<%= register._id %>" method="POST">

                            <button type="submit">
                                Generate QR
                            </button>

                        </form>

                    </div>

                    <% }) %>

            </div>

            <% } %>

</body>

</html>